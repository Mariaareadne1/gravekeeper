# Supabase — project database
SUPABASE_URL=your-project-url                  # e.g. https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key                # public client key (safe for frontend)
SUPABASE_SERVICE_KEY=your-service-role-key     # backend only, never ship to the frontend

# Backend server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000             # comma-separated allowed frontend origins

# API key gate (optional). Leave empty for local dev / the demo — the API stays open.
# Set it before exposing the API beyond localhost: real-account scans and all writes
# (review, registry) then require this value in the `X-API-Key` header. The synthetic
# demo scan and all reads stay public. Callers keep it secret; never ship it to the
# browser bundle (it is NOT an NEXT_PUBLIC_ value).
API_KEY=                                        # e.g. a long random string

# Scoring thresholds (optional overrides)
INACTIVITY_DAYS=90                             # days with no activity before an identity looks dormant

# Connectors are supplied per-scan by the user; do not hardcode cloud credentials here.
# AWS: the user attaches a read-only IAM policy and pastes temporary keys at scan time.
# GitHub: the user pastes a read-only personal access token at scan time.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000 # where the web app reaches the scanner API
